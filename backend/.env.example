# Stage Monitoring Tool — Ontwikkelomgeving
# Kopieer dit bestand naar .env en pas aan voor lokale gebruik

# Vereist voor JWT-token generatie
# Verander dit naar een sterke willekeurige string in productie!
SECRET_KEY=dev-secret-key-wijzig-dit-in-productie-1234567890

# API server poort (optioneel, default 8001)
# API_PORT=8001

# CORS origins — komma-gescheiden lijst van toegestane frontend URLs
# Gebruik '*' voor ontwikkeling (let op: niet compatibel met allow_credentials)
# Voor productie: specifieke domeinen zoals "https://staging.jouwsite.be,https://jouwsite.be"
# FRONTEND_ORIGINS=http://localhost:8080,http://localhost:3000

# Auth-cookie alleen via HTTPS versturen (default true).
# Zet op false om de cookie-login lokaal over http te testen (bv. e2e op localhost).
# LAAT IN PRODUCTIE OP true STAAN.
COOKIE_SECURE=false

# Quick-login dropdown met testaccounts (default true) — handig voor de demo.
# Zet op false in productie om GET /api/users/seed uit te schakelen.
# ENABLE_SEED_LOGIN=true
